# 프론트 (Vite)
VITE_API_BASE_URL=/api

# 백엔드 ODsay — backend/.env 또는 이 파일에 설정 (프론트에 노출하지 마세요)
# ODsay LAB Server API 키 + IP 화이트리스트 필요
ODSAY_API_KEY=

# 1이면 ODsay를 호출하지 않음 (데모 픽스처 + 혼잡 모델로 MVP 테스트)
ODSAY_FORCE_MOCK=1

# 백엔드 공공데이터포털 — 한국천문연구원 특일 정보 (공휴일)
# 공공데이터포털 마이페이지에서 Decoding 키 사용 권장
DATA_GO_API_KEY=
