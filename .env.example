# 프론트 (Vite)
VITE_API_BASE_URL=/api

# Supabase 인증·즐겨찾기 (설정 시 로컬 FastAPI 대신 사용 — 팀 공용 DB)
# https://supabase.com 대시보드 → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 백엔드 ODsay — backend/.env 또는 이 파일에 설정 (프론트에 노출하지 마세요)
# ODsay LAB Server API 키 + IP 화이트리스트 필요
ODSAY_API_KEY=

# 1이면 ODsay를 호출하지 않음 (데모 픽스처 + 혼잡 모델로 MVP 테스트)
ODSAY_FORCE_MOCK=1

# 백엔드 공공데이터포털 — Decoding 키 (특일·기상청 단기예보 등 활용신청된 API 공용)
# 공공데이터포털 마이페이지 Decoding 키. 기상청_단기예보 조회서비스 2.0 활용신청 필요.
DATA_GO_API_KEY=

# 카카오 로컬 REST API 키 (주변 지하철역 /stations/nearby) — 프론트에 노출 금지
KAKAO_REST_API_KEY=

# 카카오 지도 JavaScript 키 (프론트 — #macro 「실제 지도」 / #map)
# 카카오 개발자 콘솔에서 웹 플랫폼 도메인(localhost 등) 등록 필요
VITE_KAKAO_MAP_API_KEY=

# 서울교통공사 지하철알림(ntce) — 당일 돌발 라이브 (정체 예보 카드)
# Decoding 우선 (변수명 DECOIND — DECODE로 고치지 말 것)
TRAIN_ALERT_API_DECOIND_KEY=
# Encoding 키 폴백 (이미 %xx 인코딩된 값)
TRAIN_ALERT_API_KEY=

# 정체 예보 CSV (DB 없음·백엔드 메모리 로드)
# - data/spatic/assem-events.csv       ← npm run spatic-assem 후 커밋
# - data/metro-ntce/ntce-crowd-events.csv ← npm run metro-ntce 후 커밋
# FastAPI는 레포 루트 data/ 를 읽습니다. Vercel은 FE만 — CSV·/forecast 는 FastAPI 호스트에 필요합니다.
