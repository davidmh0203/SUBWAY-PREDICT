{
  "name": "subway-predict-dashboard",
  "description": "여유로 — 수도권 지하철 혼잡도 예측·경로 안내",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "cd backend && .venv/bin/fastapi dev app/main.py --port 8000",
    "build": "npm run extract-metro && vite build",
    "extract-metro": "node scripts/extract-metro-data.mjs",
    "verify:seoul-lines": "node scripts/verify-seoul-line-filter.mjs",
    "export-figma": "node scripts/export-figma.mjs",
    "export-figma:screens": "node scripts/capture-figma-screens.mjs",
    "export-figma:pdf": "node scripts/build-figma-pdf.mjs",
    "export-figma:all": "npm run export-figma && npm run export-figma:screens && npm run export-figma:pdf",
    "rebuild-figma-map": "bun scripts/rebuild-figma-map.mjs",
    "build-figma-wireframes": "bun scripts/build-figma-wireframes.mjs",
    "lint": "oxlint",
    "preview": "vite preview",
    "deploy": "npm run build && npx vercel --prod",
    "ship": "node scripts/ship.mjs",
    "crawl:spatic-assem": "node scripts/crawl-spatic-assem.mjs",
    "parse:spatic-assem": "node scripts/parse-spatic-assem.mjs",
    "spatic-assem": "npm run crawl:spatic-assem && npm run parse:spatic-assem",
    "crawl:smpa-assem": "node scripts/crawl-smpa-assem.mjs",
    "parse:smpa-assem": "node scripts/parse-smpa-assem.mjs",
    "smpa-assem": "npm run crawl:smpa-assem && npm run parse:smpa-assem",
    "fill:assem-personnel": "node scripts/fill-assem-personnel.mjs",
    "sync:smpa-today": "node scripts/sync-smpa-today.mjs",
    "crawl:smpa-overlap": "node scripts/crawl-smpa-assem.mjs --after 2024-03-18 --before 2099-01-01 --list-file data/spatic/raw/smpa/list-overlap.jsonl --refresh-list",
    "crawl:metro-ntce": "node scripts/crawl-metro-ntce.mjs",
    "filter:metro-ntce-events": "node scripts/filter-metro-ntce-events.mjs",
    "metro-ntce": "npm run crawl:metro-ntce && npm run filter:metro-ntce-events",
    "smoke:mock-predict": "ODSAY_FORCE_MOCK=1 backend/.venv/bin/python scripts/smoke-mock-predict.py"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-slider": "^1.4.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.16",
    "@supabase/supabase-js": "^2.110.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.52.0",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.1"
  }
}
