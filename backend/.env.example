# ODsay Server API 키 (ODsay LAB → Server 플랫폼 + IP 화이트리스트)
ODSAY_API_KEY=

# 키 없이 MVP 테스트: 1이면 searchStation/길찾기 실호출 안 함
# 데모 픽스처(시청↔동대문 등) + 로컬 혼잡 모델로 /predict/route 응답
ODSAY_FORCE_MOCK=1

# 공공데이터포털 Decoding 키
# - 한국천문연구원 특일(공휴일)
# - 기상청 단기예보 조회서비스 2.0 (날씨 카드) — 해당 API 활용신청 필요
DATA_GO_API_KEY=

# 카카오 로컬 REST API 키 (주변 지하철역 /stations/nearby)
KAKAO_REST_API_KEY=

# 서울교통공사 지하철알림(ntce) — 당일 돌발 라이브
# Decoding 우선 (철자 DECOIND). Encoding 키는 TRAIN_ALERT_API_KEY
TRAIN_ALERT_API_DECOIND_KEY=
TRAIN_ALERT_API_KEY=

# 선택: 수도권 서울 CID
ODSAY_SEOUL_CID=1000

# CORS 허용 origin (쉼표 구분). 비우면 localhost + Vercel 프로덕션 기본값
# CORS_ORIGINS=https://subway-predict-dashboard.vercel.app,http://localhost:5173

# 회원가입/로그인 JWT 서명 키 — 운영 배포 전 반드시 랜덤 값으로 교체 (예: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=dev-insecure-secret-change-me
JWT_ALGORITHM=HS256
# 액세스 토큰 만료(분). 기본 10080분 = 7일
JWT_EXPIRE_MINUTES=10080

# 정체 예보 CSV (Postgres 등 DB 불필요)
# 레포 루트 data/spatic/assem-events.csv, data/metro-ntce/ntce-crowd-events.csv
# 갱신: npm run spatic-assem / npm run metro-ntce 후 커밋·백엔드 재배포
